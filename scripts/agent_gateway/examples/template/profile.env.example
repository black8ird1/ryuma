# ─────────────────────────────────────────────────────────────────────────────
# TEMPLATE profile — copy this folder to wire the gateway to YOUR project.
#
#   cp -r scripts/agent_gateway/examples/template scripts/agent_gateway/examples/myproject
#   # edit the three files, then point a bot profile at this env:
#   source scripts/agent_gateway/examples/myproject/profile.env   # (or set these in the profile)
#
# Nothing here is baked into the bot core — every value is optional and has a
# sane default. Delete the lines you don't need.
# ─────────────────────────────────────────────────────────────────────────────

# Brand shown on the live card and the startup "online" message.
AGENT_GATEWAY_BRAND_NAME=My Agent
AGENT_GATEWAY_BRAND_EMOJI=🤖

# Your project's instructions (system prompt). Point at a file in your repo.
AGENT_GATEWAY_SYSTEM_PROMPT_FILE=scripts/agent_gateway/examples/template/system-prompt.md

# The repo agents operate on. Defaults to the gateway's own repo; set this to run
# the bot against a DIFFERENT checkout.
# AGENT_GATEWAY_REPO_ROOT=/path/to/your/repo

# Where per-agent isolated worktrees live. Defaults to a dir under your home.
# AGENT_GATEWAY_WORKTREE_ROOT=~/.agent-gateway/worktrees

# Branch agents fork from AND land into. Defaults to main; set an integration
# branch (e.g. dev) so landed work never touches prod. main/master are protected
# by default — the bot refuses to auto-land there (see AGENT_GATEWAY_PROTECTED_BRANCHES).
# AGENT_GATEWAY_BASE_BRANCH=dev

# Merge behaviour. Smart-merge (default ON) auto-lands clean work and only asks
# you to confirm on a real conflict. Set to 0 to review/confirm EVERY land.
# AGENT_GATEWAY_SMART_MERGE=1

# Where /skills discovers SKILL.md folders.
# AGENT_GATEWAY_SKILLS_DIR=.claude/skills

# OPTIONAL private "brain" hook — inject project state into every turn and record
# what each agent did. This is where your edge lives; it stays OUTSIDE the engine.
# NoOp (nothing injected) if unset. See hook.py for a worked example.
# AGENT_GATEWAY_HOOK=scripts/agent_gateway/examples/template/hook.py:make_hook

# Optional: voice transcription (leave unset to attach audio as a file instead).
# GROQ_API_KEY=
